ANTHROPIC_API_KEY=your_anthropic_api_key_here
ZAPPER_API_KEY=your_zapper_api_key_here   # https://build.zapper.xyz — optional, falls back to mock data

# Turso (remote LibSQL) — required for production; falls back to local SQLite in dev
# Create a free database: turso auth login && turso db create wallet-agent-memory
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Day 12 RAG — same project as day11-rag
# Supabase: https://supabase.com → project settings → API
VOYAGE_API_KEY=your_voyage_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Langfuse — hosted observability (https://cloud.langfuse.com)
# Create a project → Settings → API Keys
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
